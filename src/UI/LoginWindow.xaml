<Window x:Class="UI.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="YJSCGAURD" Height="320" Width="400"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#2D2D30">
    <Grid Margin="20">
        <StackPanel VerticalAlignment="Center">
            <TextBlock x:Name="txtTitle" Text="비밀번호를 입력하세요." Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,0,0,20" HorizontalAlignment="Center"/>
            <PasswordBox x:Name="pwdBox" Height="30" FontSize="16" Margin="0,0,0,20" KeyDown="pwdBox_KeyDown" VerticalContentAlignment="Center"/>
            
            <TextBlock x:Name="txtConfirmTitle" Text="비밀번호 확인:" Foreground="White" FontSize="14" FontWeight="Bold" Margin="0,0,0,5" Visibility="Collapsed"/>
            <PasswordBox x:Name="pwdConfirmBox" Height="30" FontSize="16" Margin="0,0,0,20" Visibility="Collapsed" KeyDown="pwdBox_KeyDown" VerticalContentAlignment="Center"/>

            <CheckBox x:Name="chkAutoLogin" Content="자동 로그인" Foreground="White" Margin="0,0,0,15" HorizontalAlignment="Center"/>

            <Button x:Name="btnLogin" Content="접속" Height="35" FontSize="14" Background="#007ACC" Foreground="White" FontWeight="Bold" Click="btnLogin_Click" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</Window>
