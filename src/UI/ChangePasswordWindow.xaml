<Window x:Class="UI.ChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="YJSCGAURD" Height="300" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#1E1E1E">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="현재 비밀번호 확인" Foreground="White" FontSize="14" FontWeight="Bold" Margin="0,0,0,5"/>
        <PasswordBox Grid.Row="1" x:Name="pwdCurrent" Height="30" FontSize="16" Margin="0,0,0,15" VerticalContentAlignment="Center"/>

        <TextBlock Grid.Row="2" Text="새 비밀번호 입력" Foreground="White" FontSize="14" FontWeight="Bold" Margin="0,0,0,5"/>
        <PasswordBox Grid.Row="3" x:Name="pwdNew" Height="30" FontSize="16" Margin="0,0,0,15" VerticalContentAlignment="Center"/>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button x:Name="btnConfirm" Content="변경 승인" Width="100" Height="35" Background="#4CAF50" Foreground="White" FontWeight="Bold" Click="btnConfirm_Click" Cursor="Hand" BorderThickness="0" Margin="0,0,20,0"/>
            <Button x:Name="btnCancel" Content="취소" Width="100" Height="35" Background="#FF4444" Foreground="White" FontWeight="Bold" Click="btnCancel_Click" Cursor="Hand" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>
