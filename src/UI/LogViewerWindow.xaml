<Window x:Class="UI.LogViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="YJSCGAURD 로그 뷰어" Height="400" Width="600"
        WindowStartupLocation="CenterScreen" Background="#1E1E1E">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="보안 접근 및 이벤트 로그" Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

        <ListBox Grid.Row="1" x:Name="lstLogs" Background="#2D2D30" Foreground="LightGray" FontFamily="Consolas" Margin="0,0,0,10"/>

        <Button Grid.Row="2" Content="닫기" Width="100" Height="30" HorizontalAlignment="Right" Click="btnClose_Click"/>
    </Grid>
</Window>
